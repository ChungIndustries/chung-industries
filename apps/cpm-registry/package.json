{
  "name": "cpm-registry",
  "version": "0.0.0",
  "private": true,
  "description": "Express API for the official CPM registry, hosting Lua-based cpm packages.",
  "author": "chrille0313",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "gen-docs": "tsx src/gen-docs.ts",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "cross-env": "^10.1.0",
    "dotenv-flow": "^4.1.0",
    "express": "^5.2.1",
    "express-fileupload": "^1.5.2",
    "express-zod-api": "^26.0.0",
    "http-errors": "^2.0.1",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@total-typescript/tsconfig": "^1.0.4",
    "@types/express": "^5.0.6",
    "@types/express-fileupload": "^1.5.1",
    "@types/http-errors": "^2.0.5",
    "@types/node": "^26.0.1",
    "@workspace/lint-config": "workspace:*",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
