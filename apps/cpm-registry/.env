# Public, non-secret defaults (committed). Validated by src/env.ts (zod).
#
# Multiple environments use the standard cascade, loaded by dotenv-flow:
#   .env                  this file — shared, public defaults
#   .env.<NODE_ENV>       per-environment overrides (e.g. .env.production)
#   .env.local            machine-local secrets (gitignored)
#   .env.<NODE_ENV>.local per-environment local secrets (gitignored)
# Real process env always wins, so deploys can inject values directly.

# API server
HOST=0.0.0.0
PORT=3000

# Tarball + registry.json storage
STORAGE_DIR=storage
