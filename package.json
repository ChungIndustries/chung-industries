{
  "name": "chung-industries",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nx run-many -t dev",
    "build": "nx run-many -t build",
    "lint": "nx run-many -t lint",
    "lint:fix": "nx run-many -t lint:fix",
    "typecheck": "nx run-many -t typecheck",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test": "nx run-many -t test",
    "graph": "nx graph",
    "affected": "nx affected",
    "release": "nx release",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:gen-types": "supabase gen types typescript --local > packages/supabase/src/types.gen.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@nx/js": "23.0.1",
    "@workspace/lint-config": "workspace:*",
    "husky": "^9.1.7",
    "nx": "^23.0.1",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.59.0",
    "oxlint-tsgolint": "^0.20.0"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "undici": "^7.28.0",
      "ws": "^8.21.0",
      "qs": "^6.15.2",
      "@babel/core": "^7.29.6",
      "esbuild": "^0.28.1"
    }
  }
}
